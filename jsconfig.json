{
  "compilerOptions": {
    "checkJs": true,
    "noEmit": true,
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": ["*.js", "scripts/**/*.js", "tests/**/*.js", "types.d.ts"],
  "exclude": ["node_modules"]
}
